{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudhelm.local/schemas/events/task-event.schema.json",
  "title": "CloudHelm Task Event",
  "description": "CloudHelm 任务事件流的基础结构。M2-M5 已接入真实 event_logs，事件来自数据库而非内存模拟。",
  "type": "object",
  "required": ["id", "task_id", "event_type", "actor_type", "created_at", "payload"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "EventLog UUID。"
    },
    "task_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "事件所属任务 ID；ProjectCreated 等项目级事件可为空。"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "ProjectCreated",
        "TaskCreated",
        "TaskPaused",
        "TaskResumed",
        "TaskCancelled",
        "TaskPhaseChanged",
        "RequirementSpecCreated",
        "RequirementSpecApproved",
        "RequirementSpecChangesRequested",
        "TechnicalDesignCreated",
        "TechnicalDesignApproved",
        "TechnicalDesignChangesRequested",
        "DevelopmentPlanCreated",
        "DevelopmentPlanApproved",
        "DevelopmentPlanChangesRequested",
        "AgentRunRecorded",
        "AgentRunStarted",
        "AgentRunCompleted",
        "AgentRunFailed",
        "ToolCallRecorded",
        "ToolCallStarted",
        "ToolCallSucceeded",
        "ToolCallFailed",
        "ApprovalRequested",
        "ApprovalApproved",
        "ApprovalRejected"
      ],
      "description": "M2-M5 真实写入的事件类型。"
    },
    "actor_type": {
      "type": "string",
      "description": "触发者类型，例如 user、agent、orchestrator、system。"
    },
    "actor_id": {
      "type": ["string", "null"],
      "description": "触发者标识。"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "事件创建时间，使用 UTC ISO 8601。"
    },
    "payload": {
      "type": "object",
      "description": "事件载荷。具体字段由事件类型决定。",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
