{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudhelm.local/schemas/events/task-event.schema.json",
  "title": "CloudHelm Task Event",
  "description": "CloudHelm 事件流的基础结构。M2-M7-2B2 已接入真实 event_logs，事件来自数据库而非内存模拟；项目级与环境级事件的 task_id 可为空。",
  "type": "object",
  "required": ["id", "task_id", "event_type", "actor_type", "created_at", "payload"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "EventLog UUID。"
    },
    "task_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "事件所属任务 ID；ProjectCreated 等项目级事件可为空。"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "ProjectCreated",
        "TaskCreated",
        "TaskPaused",
        "TaskResumed",
        "TaskCancelled",
        "TaskPhaseChanged",
        "RequirementSpecCreated",
        "RequirementSpecApproved",
        "RequirementSpecChangesRequested",
        "TechnicalDesignCreated",
        "TechnicalDesignApproved",
        "TechnicalDesignChangesRequested",
        "DevelopmentPlanCreated",
        "DevelopmentPlanApproved",
        "DevelopmentPlanChangesRequested",
        "AgentRunRecorded",
        "AgentRunStarted",
        "AgentRunCompleted",
        "AgentRunFailed",
        "AgentRunCancelled",
        "AgentConversationCreated",
        "AgentConversationStopped",
        "SubagentSpawned",
        "SubagentCompleted",
        "SubagentStopped",
        "ToolCallRecorded",
        "ToolCallStarted",
        "ToolCallSucceeded",
        "ToolCallFailed",
        "ToolCallRejected",
        "ToolCallCancelled",
        "ApprovalRequested",
        "ApprovalApproved",
        "ApprovalRejected",
        "ApprovalExpired",
        "LocalDevelopmentStarted",
        "ScaffoldCompleted",
        "CodePatchGenerated",
        "TestRunStarted",
        "TestRunPassed",
        "TestRunFailed",
        "ReviewCompleted",
        "SecurityScanCompleted",
        "SecurityScanBlocked",
        "ArtifactCreated",
        "BranchCreated",
        "CommitCreated",
        "PullRequestRecordCreated",
        "RepositoryBindingConfigured",
        "WorkflowJobQueued",
        "ReleaseCandidateApprovalRequested",
        "ReleaseCandidateApproved",
        "ReleaseCandidateRejected",
        "EnvironmentCreated",
        "RemoteTargetRegistered",
        "RemoteAgentHeartbeat",
        "RemoteAgentOnline",
        "RemoteAgentOffline",
        "RemoteAgentRecovered"
      ],
      "description": "M2-M7-2B2 真实写入的事件类型。"
    },
    "actor_type": {
      "type": "string",
      "description": "触发者类型，例如 user、agent、orchestrator、system。"
    },
    "actor_id": {
      "type": ["string", "null"],
      "description": "触发者标识。"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "事件创建时间，使用 UTC ISO 8601。"
    },
    "payload": {
      "type": "object",
      "description": "事件载荷。具体字段由事件类型决定。",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "RepositoryBindingConfigured"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "required": [
          "task_id",
          "actor_type",
          "actor_id",
          "payload"
        ],
        "properties": {
          "task_id": {
            "type": "null"
          },
          "actor_type": {
            "const": "system"
          },
          "actor_id": {
            "const": "repository-profile"
          },
          "payload": {
            "type": "object",
            "required": [
              "project_id",
              "repository_binding_id",
              "profile_key",
              "provider",
              "repository_external_id",
              "repository_owner",
              "repository_name",
              "default_branch",
              "workflow_id",
              "release_ref_prefix",
              "status",
              "created",
              "configuration_changed",
              "stale_candidate_ids",
              "expired_approval_ids"
            ],
            "properties": {
              "project_id": {
                "type": "string",
                "format": "uuid"
              },
              "repository_binding_id": {
                "type": "string",
                "format": "uuid"
              },
              "profile_key": {
                "type": "string"
              },
              "provider": {
                "const": "gitea"
              },
              "repository_external_id": {
                "type": "string"
              },
              "repository_owner": {
                "type": "string"
              },
              "repository_name": {
                "type": "string"
              },
              "default_branch": {
                "type": "string"
              },
              "workflow_id": {
                "type": "string"
              },
              "release_ref_prefix": {
                "type": "string"
              },
              "status": {
                "enum": [
                  "active",
                  "disabled"
                ]
              },
              "created": {
                "type": "boolean"
              },
              "configuration_changed": {
                "type": "boolean"
              },
              "stale_candidate_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uuid"
                }
              },
              "expired_approval_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "WorkflowJobQueued"
          }
        },
        "required": ["event_type"]
      },
      "then": {
        "required": ["task_id", "actor_type", "actor_id", "payload"],
        "properties": {
          "task_id": {
            "type": "string",
            "format": "uuid"
          },
          "actor_type": {
            "const": "system"
          },
          "actor_id": {
            "const": "release-candidate"
          },
          "payload": {
            "type": "object",
            "required": [
              "candidate_id",
              "approval_id",
              "workflow_job_id",
              "pull_request_record_id",
              "repository_binding_id",
              "binding_snapshot_sha256",
              "candidate_request_hash",
              "job_type",
              "job_request_hash",
              "status"
            ],
            "properties": {
              "candidate_id": {
                "type": "string",
                "format": "uuid"
              },
              "approval_id": {
                "type": "string",
                "format": "uuid"
              },
              "workflow_job_id": {
                "type": "string",
                "format": "uuid"
              },
              "pull_request_record_id": {
                "type": "string",
                "format": "uuid"
              },
              "repository_binding_id": {
                "type": "string",
                "format": "uuid"
              },
              "binding_snapshot_sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "candidate_request_hash": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "job_type": {
                "const": "release_candidate_reconcile"
              },
              "job_request_hash": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "status": {
                "const": "pending"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "ReleaseCandidateApprovalRequested"
          }
        },
        "required": ["event_type"]
      },
      "then": {
        "required": ["task_id", "actor_type", "actor_id", "payload"],
        "properties": {
          "task_id": {
            "type": "string",
            "format": "uuid"
          },
          "actor_type": {
            "const": "system"
          },
          "actor_id": {
            "type": "string",
            "format": "uuid"
          },
          "payload": {
            "type": "object",
            "required": [
              "candidate_id",
              "approval_id",
              "workflow_job_id",
              "pull_request_record_id",
              "repository_binding_id",
              "binding_snapshot_sha256",
              "candidate_request_hash",
              "action",
              "risk_level",
              "status"
            ],
            "properties": {
              "candidate_id": {
                "type": "string",
                "format": "uuid"
              },
              "approval_id": {
                "type": "string",
                "format": "uuid"
              },
              "workflow_job_id": {
                "type": "string",
                "format": "uuid"
              },
              "pull_request_record_id": {
                "type": "string",
                "format": "uuid"
              },
              "repository_binding_id": {
                "type": "string",
                "format": "uuid"
              },
              "binding_snapshot_sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "candidate_request_hash": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "action": {
                "const": "approve_release_candidate"
              },
              "risk_level": {
                "const": "L2"
              },
              "status": {
                "const": "pending_approval"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "ReleaseCandidateApproved"
          }
        },
        "required": ["event_type"]
      },
      "then": {
        "required": ["task_id", "actor_type", "actor_id", "payload"],
        "properties": {
          "task_id": {
            "type": "string",
            "format": "uuid"
          },
          "actor_type": {
            "const": "user"
          },
          "actor_id": {
            "type": "string",
            "minLength": 1
          },
          "payload": {
            "type": "object",
            "required": [
              "candidate_id",
              "approval_id",
              "pull_request_record_id",
              "repository_binding_id",
              "binding_snapshot_sha256",
              "candidate_request_hash",
              "status",
              "reason"
            ],
            "properties": {
              "candidate_id": {
                "type": "string",
                "format": "uuid"
              },
              "approval_id": {
                "type": "string",
                "format": "uuid"
              },
              "pull_request_record_id": {
                "type": "string",
                "format": "uuid"
              },
              "repository_binding_id": {
                "type": "string",
                "format": "uuid"
              },
              "binding_snapshot_sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "candidate_request_hash": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "status": {
                "const": "approved"
              },
              "reason": {
                "type": ["string", "null"]
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "ReleaseCandidateRejected"
          }
        },
        "required": ["event_type"]
      },
      "then": {
        "required": ["task_id", "actor_type", "actor_id", "payload"],
        "properties": {
          "task_id": {
            "type": "string",
            "format": "uuid"
          },
          "actor_type": {
            "const": "user"
          },
          "actor_id": {
            "type": "string",
            "minLength": 1
          },
          "payload": {
            "type": "object",
            "required": [
              "candidate_id",
              "approval_id",
              "pull_request_record_id",
              "repository_binding_id",
              "binding_snapshot_sha256",
              "candidate_request_hash",
              "status",
              "reason"
            ],
            "properties": {
              "candidate_id": {
                "type": "string",
                "format": "uuid"
              },
              "approval_id": {
                "type": "string",
                "format": "uuid"
              },
              "pull_request_record_id": {
                "type": "string",
                "format": "uuid"
              },
              "repository_binding_id": {
                "type": "string",
                "format": "uuid"
              },
              "binding_snapshot_sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "candidate_request_hash": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "status": {
                "const": "rejected"
              },
              "reason": {
                "type": ["string", "null"]
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
