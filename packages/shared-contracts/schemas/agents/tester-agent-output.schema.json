{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudhelm.local/schemas/agents/tester-agent-output.schema.json",
  "title": "TesterAgentOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "development_plan_id",
    "summary",
    "status",
    "acceptance_results",
    "risk_level"
  ],
  "properties": {
    "task_id": {"type": "string", "format": "uuid"},
    "development_plan_id": {"type": "string", "format": "uuid"},
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "status": {
      "type": "string",
      "enum": ["passed", "failed", "partial", "blocked"]
    },
    "commands": {
      "type": "array",
      "items": {"$ref": "./agent-common.schema.json#/$defs/CommandExecution"}
    },
    "passed_count": {"type": ["integer", "null"], "minimum": 0},
    "failed_count": {"type": ["integer", "null"], "minimum": 0},
    "skipped_count": {"type": ["integer", "null"], "minimum": 0},
    "acceptance_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion_id", "status", "notes"],
        "properties": {
          "criterion_id": {
            "type": "string",
            "pattern": "^AC-(?:[A-Z0-9]+-)*[0-9]{3}$"
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "not_covered"]
          },
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string"}
          },
          "notes": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          }
        }
      }
    },
    "tool_calls": {
      "type": "array",
      "items": {"$ref": "./agent-common.schema.json#/$defs/ToolCallEvidence"}
    },
    "artifacts": {
      "type": "array",
      "items": {"$ref": "./agent-common.schema.json#/$defs/ArtifactEvidence"}
    },
    "failure_reasons": {"type": "array", "items": {"type": "string"}},
    "risk_level": {"$ref": "./agent-common.schema.json#/$defs/RiskLevel"}
  }
}
