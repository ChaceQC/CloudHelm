{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudhelm.local/schemas/agents/reviewer-agent-output.schema.json",
  "title": "ReviewerAgentOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "development_plan_id",
    "summary",
    "verdict",
    "acceptance_results",
    "changed_files",
    "proceed_to_security",
    "risk_level"
  ],
  "properties": {
    "task_id": {"type": "string", "format": "uuid"},
    "development_plan_id": {"type": "string", "format": "uuid"},
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "verdict": {
      "type": "string",
      "enum": ["approved", "changes_requested", "blocked"]
    },
    "acceptance_results": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "./agent-common.schema.json#/$defs/AcceptanceReview"}
    },
    "issues": {
      "type": "array",
      "items": {"$ref": "./agent-common.schema.json#/$defs/ReviewIssue"}
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "./agent-common.schema.json#/$defs/ChangedFile"}
    },
    "tool_calls": {
      "type": "array",
      "items": {"$ref": "./agent-common.schema.json#/$defs/ToolCallEvidence"}
    },
    "proceed_to_security": {"type": "boolean"},
    "risk_level": {"$ref": "./agent-common.schema.json#/$defs/RiskLevel"}
  }
}
