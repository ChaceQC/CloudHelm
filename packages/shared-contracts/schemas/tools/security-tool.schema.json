{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudhelm.local/schemas/tools/security-tool.schema.json",
  "title": "CloudHelm Security Tool",
  "description": "M6 Security Tool 执行 Bandit 与 pip-audit，返回结构化代码和依赖安全证据。",
  "type": "object",
  "required": ["tools"],
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "risk_level", "requires_approval", "arguments"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["security.run_bandit", "security.run_pip_audit"]
          },
          "risk_level": {
            "type": "string",
            "enum": ["L1"]
          },
          "requires_approval": {
            "type": "boolean",
            "const": false
          },
          "arguments": {
            "type": "object",
            "required": ["workspace_root"],
            "properties": {
              "workspace_root": {"type": "string"},
              "cwd": {
                "type": "string",
                "default": "."
              },
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240,
                "default": "src"
              },
              "timeout_seconds": {
                "type": "integer",
                "minimum": 1,
                "maximum": 300
              },
              "max_output_chars": {
                "type": "integer",
                "minimum": 200,
                "maximum": 50000,
                "default": 12000
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
