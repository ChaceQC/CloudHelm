{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudhelm.local/schemas/tools/git-tool.schema.json",
  "title": "CloudHelm Git Tool",
  "description": "M5-M6 Git Tool 支持 status、diff、create_branch、commit、format_patch；不执行 push、rebase、destructive reset 或 release tag。",
  "type": "object",
  "required": ["tools"],
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "risk_level", "requires_approval", "arguments"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "git.status",
              "git.diff",
              "git.create_branch",
              "git.commit",
              "git.format_patch"
            ]
          },
          "risk_level": {
            "type": "string",
            "enum": ["L0", "L2"]
          },
          "requires_approval": {
            "type": "boolean",
            "const": false
          },
          "arguments": {
            "type": "object",
            "required": ["repo_root"],
            "properties": {
              "repo_root": {"type": "string"},
              "porcelain": {"type": "boolean", "default": true},
              "paths": {
                "type": "array",
                "items": {"type": "string"}
              },
              "from_ref": {
                "type": ["string", "null"],
                "maxLength": 120
              },
              "to_ref": {
                "type": ["string", "null"],
                "maxLength": 120
              },
              "include_untracked": {"type": "boolean", "default": true},
              "context_lines": {
                "type": "integer",
                "minimum": 0,
                "maximum": 20,
                "default": 3
              },
              "max_output_chars": {
                "type": "integer",
                "minimum": 100,
                "maximum": 1000000
              },
              "branch_name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              },
              "message": {
                "type": "string",
                "minLength": 3,
                "maxLength": 200
              },
              "base_ref": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120,
                "default": "main"
              },
              "head_ref": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120,
                "default": "HEAD"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
