{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudhelm.local/schemas/tools/repo-tool.schema.json",
  "title": "CloudHelm Repo Tool",
  "description": "M5-M6 Repo Tool 在受控 workspace_root 内读、搜、列出和以 UTF-8 replace 写入文本文件。",
  "type": "object",
  "required": ["tools"],
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "risk_level", "requires_approval", "arguments"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "repo.read_file",
              "repo.search_text",
              "repo.write_file",
              "repo.list_files"
            ]
          },
          "risk_level": {
            "type": "string",
            "enum": ["L0", "L1"]
          },
          "requires_approval": {
            "type": "boolean",
            "const": false
          },
          "arguments": {
            "type": "object",
            "required": ["workspace_root"],
            "properties": {
              "workspace_root": {"type": "string"},
              "path": {"type": "string"},
              "max_bytes": {
                "type": "integer",
                "minimum": 1,
                "maximum": 262144,
                "default": 65536
              },
              "content": {
                "type": "string",
                "maxLength": 262144
              },
              "mode": {
                "type": "string",
                "const": "replace",
                "default": "replace"
              },
              "create_parent": {
                "type": "boolean",
                "default": false
              },
              "expected_sha256": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^(missing|sha256:[0-9a-f]{64})$"
                  },
                  {"type": "null"}
                ],
                "default": null
              },
              "pattern": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200
              },
              "glob": {
                "type": "string",
                "default": "**/*"
              },
              "case_sensitive": {
                "type": "boolean",
                "default": false
              },
              "max_matches": {
                "type": "integer",
                "minimum": 1,
                "maximum": 200,
                "default": 50
              },
              "max_file_bytes": {
                "type": "integer",
                "minimum": 1,
                "maximum": 262144,
                "default": 65536
              },
              "include_dirs": {
                "type": "boolean",
                "default": false
              },
              "limit": {
                "type": "integer",
                "minimum": 1,
                "maximum": 500,
                "default": 100
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
