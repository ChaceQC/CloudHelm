CLOUDHELM_ENV=development
CLOUDHELM_VERSION=0.5.1
CLOUDHELM_API_HOST=127.0.0.1
CLOUDHELM_API_PORT=18080
CLOUDHELM_DATABASE_URL=postgresql+psycopg://cloudhelm:cloudhelm_dev@127.0.0.1:15432/cloudhelm
# pytest 默认不使用上面的开发库，而是按 cloudhelm_test_<pid>_<uuid> 创建并
# 删除会话级随机数据库。仅复用专用测试库时取消下一行注释；数据库名必须包含
# 独立 test 段。
# CLOUDHELM_TEST_DATABASE_URL=postgresql+psycopg://cloudhelm:cloudhelm_dev@127.0.0.1:15432/cloudhelm_test
# 显式测试库会重建 public schema，需人工改为 true 才允许执行。
CLOUDHELM_TEST_ALLOW_SCHEMA_RESET=false
CLOUDHELM_POSTGRES_USER=cloudhelm
CLOUDHELM_POSTGRES_PASSWORD=cloudhelm_dev
CLOUDHELM_POSTGRES_DB=cloudhelm
CLOUDHELM_POSTGRES_PORT=15432
# Redis 为 M7-2C Workflow Engine broker；PostgreSQL workflow_jobs 仍是业务权威。
CLOUDHELM_REDIS_URL=redis://127.0.0.1:16379/0
CLOUDHELM_REDIS_PORT=16379
# M7-2C Workflow Engine。broker message 只携带 workflow_job_id；以下默认值须
# 同时满足 heartbeat/lease、publish/dispatch lease 与 visibility 不变量。
CLOUDHELM_WORKFLOW_BROKER_URL=redis://127.0.0.1:16379/0
CLOUDHELM_WORKFLOW_QUEUE_NAME=cloudhelm.workflow
CLOUDHELM_WORKFLOW_MAINTENANCE_QUEUE_NAME=cloudhelm.workflow.maintenance
CLOUDHELM_WORKFLOW_JOB_LEASE_SECONDS=90
CLOUDHELM_WORKFLOW_JOB_HEARTBEAT_SECONDS=20
CLOUDHELM_WORKFLOW_DISPATCH_INTERVAL_SECONDS=5
CLOUDHELM_WORKFLOW_DISPATCH_LEASE_SECONDS=15
CLOUDHELM_WORKFLOW_BROKER_PUBLISH_TIMEOUT_SECONDS=5
CLOUDHELM_WORKFLOW_REDISPATCH_AFTER_SECONDS=60
CLOUDHELM_WORKFLOW_ENQUEUE_BACKOFF_SECONDS=1
CLOUDHELM_WORKFLOW_MAX_ENQUEUE_BACKOFF_SECONDS=60
CLOUDHELM_WORKFLOW_RETRY_BACKOFF_SECONDS=5
CLOUDHELM_WORKFLOW_MAX_RETRY_BACKOFF_SECONDS=300
CLOUDHELM_WORKFLOW_RECLAIM_INTERVAL_SECONDS=30
CLOUDHELM_WORKFLOW_BATCH_SIZE=50
CLOUDHELM_WORKFLOW_SOFT_TIME_LIMIT_SECONDS=840
CLOUDHELM_WORKFLOW_HARD_TIME_LIMIT_SECONDS=900
CLOUDHELM_WORKFLOW_VISIBILITY_TIMEOUT_SECONDS=1800
# M5 单实例 Tool Gateway 限流；多 worker/远端阶段需迁移到共享存储。
CLOUDHELM_TOOL_RATE_LIMIT_CALLS=60
CLOUDHELM_TOOL_RATE_LIMIT_WINDOW_SECONDS=60
# JSON 数组；空数组默认拒绝 Repo、Sandbox 和 Git 工作区访问。
CLOUDHELM_TOOL_WORKSPACE_ROOTS=[]
# M6 受控本地开发：路径由 Platform API 注入，HTTP 请求和模型不能覆盖。
CLOUDHELM_TOOL_MAX_TIMEOUT_SECONDS=300
CLOUDHELM_TOOL_MAX_OUTPUT_CHARS=50000
CLOUDHELM_M6_SAMPLE_REPO_ROOT=D:/path/to/CloudHelm/examples/sample-repo-python
CLOUDHELM_M6_RECIPE_ROOT=D:/path/to/CloudHelm/examples/sample-repo-python/demo-issues
CLOUDHELM_M6_WORKSPACE_ROOT=D:/path/to/CloudHelm/output/m6-workspaces
CLOUDHELM_ARTIFACT_ROOT=D:/path/to/CloudHelm/output/artifacts
CLOUDHELM_ARTIFACT_PREVIEW_BYTES=65536
CLOUDHELM_M6_BRANCH_PREFIX=codex
# M4/M5 Agent provider。默认 local_structured 只支持受控 auth/profile demo
# issue 与 CloudHelm M4 核验 recipe；其他领域返回 unsupported_local_recipe。
# 切换 openai_compatible 时默认走 Responses API，并可把显式模型字符串
# gpt-5.6-sol 与 reasoning.effort=xhigh 透传给已配置的兼容端点。
CLOUDHELM_AGENT_PROVIDER=local_structured
CLOUDHELM_LLM_PROVIDER=
CLOUDHELM_LLM_MODEL=gpt-5.6-sol
CLOUDHELM_LLM_API_BASE=
CLOUDHELM_LLM_API_KEY=
CLOUDHELM_LLM_API_MODE=responses
CLOUDHELM_LLM_REASONING_EFFORT=xhigh
CLOUDHELM_LLM_REASONING_SUMMARY=auto
CLOUDHELM_LLM_REASONING_CONTEXT=all_turns
CLOUDHELM_LLM_MAX_OUTPUT_TOKENS=32768
CLOUDHELM_LLM_TIMEOUT_SECONDS=120
CLOUDHELM_LLM_MAX_ATTEMPTS=3
CLOUDHELM_LLM_RETRY_BACKOFF_SECONDS=1
# 官方显式协议会发送 prompt_cache_options/prompt_cache_breakpoint；当前兼容
# 端点的真实能力探测返回 502，因此默认依靠稳定前缀自动缓存。
CLOUDHELM_LLM_EXPLICIT_CACHE_BREAKPOINT=false
# 某些 Codex 路由兼容端点会拒绝缺少 Codex User-Agent 的请求。
CLOUDHELM_LLM_USER_AGENT=codex_cli_rs/0.0.0 (CloudHelm)
CLOUDHELM_LLM_ORIGINATOR=codex_cli_rs
# 参考 Codex CLI：默认只允许 root 创建直接 child，并限制单 Task active threads。
CLOUDHELM_AGENT_MAX_SUBAGENT_DEPTH=1
CLOUDHELM_AGENT_MAX_SUBAGENT_THREADS=6
# M7-2B Platform API：RepositoryProfile 只由服务端注入。普通 API 仅接受
# profile_key；clone URL、credential ref、workflow 和 release ref 均不可覆盖。
CLOUDHELM_REPOSITORY_PROFILES={}
# CLOUDHELM_REPOSITORY_PROFILES_FILE=D:/secure/cloudhelm/repository-profiles.json
# credential_ref -> repository token/credential 的 JSON map；示例保持空对象。
CLOUDHELM_REPOSITORY_CREDENTIALS={}
# M7-1 Platform API：RemoteTarget profile 与 machine credential 仅由服务端注入。
# 二选一提供 profile JSON map 或权限受控 UTF-8 文件；示例不包含真实 endpoint、
# fingerprint 或 secret。
CLOUDHELM_REMOTE_TARGET_PROFILES={}
# CLOUDHELM_REMOTE_TARGET_PROFILES_FILE=D:/secure/cloudhelm/remote-target-profiles.json
# credential_ref -> secret 的 JSON map；本文件必须保持空对象，真实值运行时注入。
CLOUDHELM_REMOTE_AGENT_CREDENTIALS={}
CLOUDHELM_REMOTE_AGENT_TIMESTAMP_TOLERANCE_SECONDS=300
CLOUDHELM_REMOTE_AGENT_NONCE_TTL_SECONDS=900
CLOUDHELM_REMOTE_AGENT_OFFLINE_TIMEOUT_SECONDS=60
CLOUDHELM_REMOTE_AGENT_HEARTBEAT_EVENT_INTERVAL_SECONDS=300
CLOUDHELM_REMOTE_AGENT_NEXT_HEARTBEAT_SECONDS=20
CLOUDHELM_REMOTE_AGENT_HEARTBEAT_MAX_BODY_BYTES=16384
# M7-1 Remote Agent 独立进程配置。Platform API origin 强制 HTTPS，target 为 UUID，
# secret 只从 credential file 读取；按实际主机取消注释。
# CLOUDHELM_REMOTE_AGENT_PLATFORM_API_BASE_URL=https://platform.example.test
# CLOUDHELM_REMOTE_AGENT_TARGET_ID=00000000-0000-0000-0000-000000000201
# CLOUDHELM_REMOTE_AGENT_AGENT_ID=remote-agent-demo
# CLOUDHELM_REMOTE_AGENT_KEY_ID=key-2026-07-a
# CLOUDHELM_REMOTE_AGENT_CREDENTIAL_FILE=/run/credentials/cloudhelm-machine-secret
# CLOUDHELM_REMOTE_AGENT_PLATFORM_CA_BUNDLE=/etc/cloudhelm/platform-ca.pem
# CLOUDHELM_REMOTE_AGENT_HEARTBEAT_SECONDS=20
# CLOUDHELM_REMOTE_AGENT_REQUEST_TIMEOUT=10
# CLOUDHELM_REMOTE_AGENT_VERSION=0.5.1
# CLOUDHELM_REMOTE_AGENT_CAPABILITIES=["capabilities","health","heartbeat","version"]
VITE_CLOUDHELM_API_BASE_URL=http://127.0.0.1:18080
